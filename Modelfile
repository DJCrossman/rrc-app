# Modelfile for M2 Max optimization with llava:13b
# This configures the vision model for optimal performance on Apple Silicon

FROM llava:13b

# M2 Max specific optimizations
# Load all layers on Metal GPU (M2 Max has 30-38 GPU cores)
PARAMETER num_gpu 99
# Use 10 threads (M2 Max has 12 cores, leave 2 for system)
PARAMETER num_thread 10
# Context window size (sufficient for image analysis)
PARAMETER num_ctx 4096
# Batch size for prompt processing
PARAMETER num_batch 512
# Use fp16 for key/value cache (faster on Apple Silicon)
PARAMETER f16_kv true

# Model behavior parameters
# Low temperature for consistent structured JSON output
PARAMETER temperature 0.1
# Nucleus sampling
PARAMETER top_p 0.9
# Top-k sampling
PARAMETER top_k 40
# Prevent repetition
PARAMETER repeat_penalty 1.1

# Keep model loaded in memory for 1 hour to avoid cold starts
# Keep first 4 tokens in context
PARAMETER num_keep 4
# Stop at code block end
PARAMETER stop "```"

SYSTEM """You are a vision model that extracts structured data from images. 
Always respond with valid JSON matching the requested schema. 
Be precise with numbers, dates, and times."""
